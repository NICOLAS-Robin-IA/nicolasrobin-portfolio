/*
  X-Robots-Tag: noindex, nofollow, noarchive, noimageindex
  Referrer-Policy: same-origin
  X-Content-Type-Options: nosniff
  Permissions-Policy: interest-cohort=()

/*.webp
  Cache-Control: public, max-age=31536000, immutable
  Referrer-Policy: same-origin

/*.jpg
/*.png
  Cache-Control: public, max-age=31536000, immutable
  Referrer-Policy: same-origin
