# ============================================================
# .HTACCESS — photographe.nicolasrobin.com
# À placer à la racine du site sur l'hébergeur
# ============================================================

# 1. Forcer HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Bloquer accès direct aux photos par URL
# Un visiteur ne peut pas télécharger une photo en tapant son URL directement
RewriteCond %{HTTP_REFERER} !^https://photographe\.nicolasrobin\.com [NC]
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{REQUEST_URI} \.(jpg|jpeg|png|gif|webp)$ [NC]
RewriteRule .* - [F,L]

# 3. Désactiver le listage des dossiers
# Empêche de voir la liste des fichiers dans /photos/, /menu-01/ etc.
Options -Indexes

# 4. Cache navigateur — accélère le chargement pour les visiteurs réguliers
<IfModule mod_expires.c>
  ExpiresActive On
  # Images : mises en cache 30 jours
  ExpiresByType image/jpeg        "access plus 30 days"
  ExpiresByType image/png         "access plus 30 days"
  ExpiresByType image/x-icon      "access plus 30 days"
  ExpiresByType image/svg+xml     "access plus 30 days"
  # HTML : mis en cache 1 jour
  ExpiresByType text/html         "access plus 1 day"
  # CSS/JS dans les HTML : 1 jour
  ExpiresByType text/css          "access plus 1 day"
  ExpiresByType application/javascript "access plus 1 day"
</IfModule>

# 5. Compression GZIP — réduit la taille des fichiers envoyés
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# 6. Headers de sécurité
<IfModule mod_headers.c>
  # Empêche ton site d'être intégré dans une iframe (clickjacking)
  Header always set X-Frame-Options "DENY"
  # Empêche le navigateur de deviner le type de fichier
  Header always set X-Content-Type-Options "nosniff"
  # Ne pas envoyer l'URL de ton site aux sites externes
  Header always set Referrer-Policy "no-referrer"
  # Force HTTPS pendant 1 an
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# 7. Bloquer les fichiers sensibles
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>
